{
  "name": "travel-life-os",
  "version": "4.0.0",
  "description": "Deterministic geo-life planning + financial-constraint engine for China (ages 50-80).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
